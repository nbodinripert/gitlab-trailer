{
  "name": "gitlab-trailer",
  "displayName": "GitLab MR Trailer",
  "version": "2.0.1",
  "publisher": "NicolasBodinRipert",
  "icon": "icon.png",
  "description": "Track GitLab merge requests and use AI to auto-summarize them.",
  "repository": {
    "type": "git",
    "url": "https://github.com/nbodinripert/gitlab-trailer.git"
  },
  "bugs": {
    "url": "https://github.com/nbodinripert/gitlab-trailer/issues"
  },
  "homepage": "https://github.com/nbodinripert/gitlab-trailer#readme",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "GitLab Trailer",
      "properties": {
        "gitlabTrailer.apiToken": {
          "type": "string",
          "default": "",
          "description": "%config.token%"
        },
        "gitlabTrailer.instanceUrl": {
          "type": "string",
          "default": "https://gitlab.com",
          "description": "%config.instance%"
        },
        "gitlabTrailer.projectPath": {
          "type": "string",
          "default": "",
          "description": "%config.project%"
        },
        "gitlabTrailer.aiProvider": {
          "type": "string",
          "enum": ["OpenAI", "Gemini"],
          "default": "OpenAI",
          "description": "%config.aiProvider%"
        },
        "gitlabTrailer.aiApiKey": {
          "type": "string",
          "default": "",
          "description": "%config.aiApiKey%"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitlab-trailer-view",
          "title": "GitLab MRs",
          "icon": "$(git-pull-request)"
        }
      ]
    },
    "views": {
      "gitlab-trailer-view": [
        {
          "id": "mrExplorer",
          "name": "Merge Requests",
          "icon": "$(git-pull-request)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "mrExplorer",
        "contents": "%welcome.content%"
      }
    ],
    "commands": [
      {
        "command": "gitlabTrailer.refreshEntry",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "gitlabTrailer.summarizeMR",
        "title": "AI Summary",
        "icon": "$(wand)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "gitlabTrailer.refreshEntry",
          "when": "view == mrExplorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "gitlabTrailer.summarizeMR",
          "when": "view == mrExplorer && viewItem == mr-action-ai",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "dependencies": {
    "axios": "^1.3.4"
  }
}